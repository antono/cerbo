{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-theme",
    "core:app:allow-set-app-theme",
    "core:path:default",
    "opener:default",
    "dialog:allow-open"
  ]
}
